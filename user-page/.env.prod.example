# ============================================
# Production Environment Variables
# Copy to .env and fill in actual values
# ============================================

# --- PostgreSQL ---
POSTGRES_DB=user_page_db
POSTGRES_USER=userpage
POSTGRES_PASSWORD=change-this-to-strong-password

# --- Redis ---
REDIS_PASSWORD=change-this-to-strong-password

# --- JWT ---
JWT_SECRET=change-this-to-random-256bit-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Admin Backend Integration ---
# URL of the admin backend API (for game proxy, notifications, etc.)
ADMIN_API_URL=http://host.docker.internal:8002
ADMIN_SERVICE_TOKEN=change-this-to-shared-service-token

# --- Frontend ---
# API URL as seen by the browser (relative path when using nginx proxy)
NEXT_PUBLIC_API_URL=/api

# --- Ports (host mapping) ---
HTTP_PORT=80
HTTPS_PORT=443
